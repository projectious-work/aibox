{
    "name": "aibox-base",
    "dockerComposeFile": "docker-compose.yml",
    "service": "devcontainer",
    "workspaceFolder": "/workspace",

    // Override CMD — VS Code needs the container to idle so it can exec into it.
    // Zellij is launched manually once inside, not as the container entrypoint.
    "overrideCommand": true,

    // Run as non-root user; updateRemoteUserUID syncs UID with host on Linux
    "remoteUser": "aibox",
    "updateRemoteUserUID": true,

    // Useful VS Code extensions to install into the container
    "customizations": {
        "vscode": {
            "extensions": [

            ],
            "settings": {
                // Start zellij automatically when a new VS Code terminal is opened
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    },
                    "claude": {
                        "path": "/home/aibox/.local/bin/claude"
                    },
                    "zellij": {
                        "path": "/usr/local/bin/zellij",
                        "args": [
                        "--layout",
                        "dev"
                        ]
                    }
                }
            }
        }
    },

    // Forward common dev ports if needed — add your own here
    "forwardPorts": [],

    // Run once after the container is created
    "postCreateCommand": "",

    // Keep OrbStack NAT alive — prevents network dropout after ~20min idle
    "postStartCommand": "nohup bash -c 'while true; do nslookup example.com > /dev/null 2>&1; sleep 120; done' > /dev/null 2>&1 &"
}
