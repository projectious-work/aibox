// =============================================================================
// "assist" layout — Claude-focused, code review / AI-assisted workflow
//
// Select with: zellij --layout assist
//
// Structure:
//   ┌──────────┬──────────────┬────────────────┐
//   │          │              │                │
//   │  yazi    │  ┊bash┊      │    vim         │
//   │  (20%)   │  ┊claude┊    │    (rest)      │
//   │          │  stacked     │                │
//   │          │  (40%)       │                │
//   ├──────────┴──────────────┴────────────────┤
//   │  status-bar                              │
//   └──────────────────────────────────────────┘
//
// Use this layout when you primarily work through Claude and
// only occasionally check files in vim.
// =============================================================================

layout {

    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="assist" focus=true {
        pane split_direction="vertical" {

            // Left: Yazi file manager
            pane size="20%" name="files" {
                command "yazi"
                cwd "/workspace"
            }

            // Center: stacked bash + claude (40% width)
            pane stacked=true size="40%" {
                pane name="claude" focus=true {
                    command "claude"
                    cwd "/workspace"
                }
                pane name="terminal" {
                    command "bash"
                    cwd "/workspace"
                }
            }

            // Right: vim editor (remaining 40% width)
            pane name="editor" {
                command "vim"
                cwd "/workspace"
            }
        }
    }

    tab name="git" {
        pane name="lazygit" {
            command "lazygit"
            cwd "/workspace"
        }
    }

    tab name="shell" {
        pane name="bash" {
            command "bash"
            cwd "/workspace"
        }
    }

    tab name="help" {
        pane name="cheatsheet" {
            command "less"
            args "-R" "/root/.config/cheatsheet.txt"
        }
    }
}
